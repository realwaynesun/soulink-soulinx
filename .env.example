# Lending pool wallet (holds USDC, signs transfers)
OPERATOR_PRIVATE_KEY=0x...

# Soulink API
SOULINK_BASE_URL=https://soulink.dev

# Platform fee recipient (Soulink treasury)
SOULINK_FEE_ADDRESS=0x...

# Platform fee in basis points (100 = 1%)
PLATFORM_FEE_BPS=100

# Server
PORT=4030
DB_PATH=./soulinx.db
CORS_ORIGIN=*

# X Layer
RPC_URL=https://rpc.xlayer.tech
USDG_ADDRESS=0x4ae46a509f6b1d9056937ba4500cb143933d2dc8

# SoulinXPool contract (deployed on X Layer)
POOL_CONTRACT_ADDRESS=0x...

# Pool's registered .agent name (must be owned by OPERATOR_PRIVATE_KEY)
POOL_AGENT_NAME=soulinx-pool
